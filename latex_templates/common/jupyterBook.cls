% Utility: conditionally render non-empty content
\newcommand{\ifnotempty}[2]{%
  \if\relax\detokenize{#1}\relax\else#2\fi%
}
\newcommand{\ifexpandednotempty}[2]{%
  \begingroup
  \edef\@tempa{#1}%
  \ifx\@tempa\@empty
    \endgroup
  \else
    \endgroup#2%
  \fi
}

% Running header title. Use a parbox so YAML/metadata can intentionally insert
% line breaks (`\\`) without overflowing the header rule.
\newcommand{\TeachBookRunningTitle}{%
  \if\relax\detokenize\expandafter{\BookHeaderTitle}\relax\@title\else\BookHeaderTitle\fi%
}
\newcommand{\TeachBookCoverTitle}{%
  \if\relax\detokenize\expandafter{\BookTitle}\relax\@title\else\BookTitle\fi%
}

\setlength{\headheight}{26pt}
\AtBeginDocument{%
  \@ifundefined{fancyhead}{}{%
    \fancyhead[RO,LE]{%
      \parbox[t]{0.72\textwidth}{\raggedleft\small\bfseries\TeachBookRunningTitle}%
    }%
  }%
}

